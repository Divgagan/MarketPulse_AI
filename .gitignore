# ── Secrets ───────────────────────────────────────────────────────
.env

# ── Python Cache ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ── Data Directories (large files, not committed) ─────────────────
data/raw/*
data/processed/*
data/models/*
data/chroma_db/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep
!data/chroma_db/.gitkeep

# ── SQLite Databases ──────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Model Files ───────────────────────────────────────────────────
*.pkl
*.joblib

# ── OS Files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter Notebooks (optional) ──────────────────────────────────
.ipynb_checkpoints/

# ── Virtual Environments ──────────────────────────────────────────
venv/
env/
.conda/

# ── Build / Distribution ──────────────────────────────────────────
dist/
build/
*.egg-info/

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
